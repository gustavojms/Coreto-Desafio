          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/talentos?senioridade=SENIOR&estado=PE&formato=REMOTO", "host": ["{{baseUrl}}"], "path": ["api", "v1", "talentos"], "query": [{ "key": "senioridade", "value": "SENIOR" }, { "key": "estado", "value": "PE" }, { "key": "formato", "value": "REMOTO" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
