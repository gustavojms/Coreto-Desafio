{
  "info": {
    "name": "CORETO 2.0 API",
    "description": "Colecao completa da API CORETO 2.0 - Ecossistema de Inovacao do Recife.\n\nPara comecar:\n1. Execute 'Login Admin (seed)' para obter o token\n2. As demais requisicoes usam o token automaticamente\n3. Os dados de demonstracao ja estao populados via migration V7",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{apiUrl}}" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "organizadorId", "value": "e0000000-0000-0000-0000-000000000001" },
    { "key": "oportunidadeId", "value": "f0000000-0000-0000-0000-000000000001" },
    { "key": "resolvedorId", "value": "a1000000-0000-0000-0000-000000000001" },
    { "key": "talentoId", "value": "a2000000-0000-0000-0000-000000000001" },
    { "key": "userId", "value": "a0000000-0000-0000-0000-000000000001" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}" }]
  },
  "item": [
    {
      "name": "Autenticacao",
      "description": "Registro e login de usuarios. Todos os endpoints protegidos exigem o token JWT retornado aqui.",
      "item": [
        {
          "name": "Login Admin (seed)",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "pm.collectionVariables.set('adminToken', json.token);", "pm.collectionVariables.set('token', json.token);", "pm.collectionVariables.set('userId', json.userId);", "pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Possui token', () => pm.expect(json.token).to.be.a('string'));", "pm.test('Role e ADMIN', () => pm.expect(json.role).to.equal('ADMIN'));"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@coreto.com.br\",\n  \"senha\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Registrar novo usuario",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Possui token', () => pm.expect(json.token).to.be.a('string'));", "pm.test('Possui userId', () => pm.expect(json.userId).to.be.a('string'));"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Novo Usuario\",\n  \"email\": \"novo@teste.com\",\n  \"senha\": \"123456\",\n  \"role\": \"TALENTO\"\n}" }
          }
        },
        {
          "name": "Login Organizador (seed)",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "pm.collectionVariables.set('token', json.token);", "pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"maria@emprel.com\",\n  \"senha\": \"123456\"\n}" }
          }
        },
        {
          "name": "Validacao - Email invalido",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));", "pm.test('Possui erros de campo', () => pm.expect(pm.response.json().fieldErrors).to.have.property('email'));"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Teste\",\n  \"email\": \"email-invalido\",\n  \"senha\": \"123456\",\n  \"role\": \"TALENTO\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Organizadores",
      "description": "CRUD completo de Organizadores (instituicoes promotoras do ecossistema).",
      "item": [
        {
          "name": "Criar Organizador",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "pm.collectionVariables.set('organizadorId', json.id);", "pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Possui tags', () => pm.expect(json.tags).to.be.an('array').that.is.not.empty);", "pm.test('Possui auditoria', () => { pm.expect(json.createdAt).to.be.a('string'); pm.expect(json.createdBy).to.be.a('string'); });"] } }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/organizadores",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"tipoOrganizacao\": \"UNIVERSIDADE\",\n  \"nome\": \"UFPE - Centro de Informatica\",\n  \"descricao\": \"Centro de Informatica da Universidade Federal de Pernambuco, referencia em pesquisa e inovacao.\",\n  \"descricaoCurta\": \"CIn UFPE\",\n  \"cnpj\": \"24134488000182\",\n  \"usuariosResponsaveis\": [\"{{userId}}\"],\n  \"logoUrl\": \"https://cin.ufpe.br/logo.png\",\n  \"bannerUrl\": \"https://cin.ufpe.br/banner.png\",\n  \"problemaAtuacao\": \"Formar talentos e gerar pesquisa aplicada em tecnologia\",\n  \"publicoAlvo\": [\"ESTUDANTES\", \"PESQUISADORES\"],\n  \"territorioPais\": \"Brasil\",\n  \"territorioEstado\": \"PE\",\n  \"territorioMunicipio\": \"Recife\",\n  \"areaTematica\": [\"TECNOLOGIA\", \"EDUCACAO\"],\n  \"estagioInovacao\": \"ESTAGIO_5\",\n  \"oQueBusca\": [\"REDE_CONTATOS\", \"MERCADO\"],\n  \"parceiroDesejado\": \"EMPRESA\"\n}" }
          }
        },
        {
          "name": "Buscar Organizador por ID",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('ID correto', () => pm.expect(pm.response.json().id).to.equal(pm.collectionVariables.get('organizadorId')));"] } }],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/organizadores/{{organizadorId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Listar Organizadores (paginado)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Possui paginacao', () => { var json = pm.response.json(); pm.expect(json.totalElements).to.be.a('number'); pm.expect(json.content).to.be.an('array'); });"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/organizadores?page=0&size=10&sort=createdAt,desc", "host": ["{{baseUrl}}"], "path": ["api", "v1", "organizadores"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "10" }, { "key": "sort", "value": "createdAt,desc" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Filtrar por TAG",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Resultados filtrados', () => pm.expect(pm.response.json().totalElements).to.be.above(0));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/organizadores?tag=tecnologia", "host": ["{{baseUrl}}"], "path": ["api", "v1", "organizadores"], "query": [{ "key": "tag", "value": "tecnologia" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Filtrar por texto",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/organizadores?search=recife", "host": ["{{baseUrl}}"], "path": ["api", "v1", "organizadores"], "query": [{ "key": "search", "value": "recife" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Filtrar por estado",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/organizadores?estado=PE", "host": ["{{baseUrl}}"], "path": ["api", "v1", "organizadores"], "query": [{ "key": "estado", "value": "PE" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Atualizar Organizador",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Tags recalculadas', () => pm.expect(pm.response.json().tags).to.be.an('array'));"] } }],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/organizadores/{{organizadorId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"tipoOrganizacao\": \"GOVERNO\",\n  \"nome\": \"Prefeitura do Recife - SECTI (atualizado)\",\n  \"descricao\": \"Secretaria atualizada com novos programas\",\n  \"cnpj\": \"11222333000181\",\n  \"usuariosResponsaveis\": [\"{{userId}}\"],\n  \"logoUrl\": \"https://recife.pe.gov.br/logo-v2.png\",\n  \"bannerUrl\": \"https://recife.pe.gov.br/banner-v2.png\",\n  \"areaTematica\": [\"TECNOLOGIA\", \"GOVERNO_DIGITAL\", \"EDUCACAO\"],\n  \"estagioInovacao\": \"ESTAGIO_5\",\n  \"oQueBusca\": [\"FINANCEIRO\", \"TECNOLOGIA\"],\n  \"parceiroDesejado\": \"EMPRESA\"\n}" }
          }
        },
        {
          "name": "Deletar Organizador (soft delete)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }],
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/organizadores/{{organizadorId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Buscar deletado (espera 404)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"] } }],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/organizadores/{{organizadorId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Oportunidades",
