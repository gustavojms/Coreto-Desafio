          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/oportunidades?tipo=EDITAL&tag=tecnologia&status=ABERTA&page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api", "v1", "oportunidades"], "query": [{ "key": "tipo", "value": "EDITAL" }, { "key": "tag", "value": "tecnologia" }, { "key": "status", "value": "ABERTA" }, { "key": "page", "value": "0" }, { "key": "size", "value": "10" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Filtrar por texto",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/oportunidades?search=backend", "host": ["{{baseUrl}}"], "path": ["api", "v1", "oportunidades"], "query": [{ "key": "search", "value": "backend" }] }, "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
