          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] } }],
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/talentos/{{talentoId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Security",
      "item": [
        {
          "name": "No Token (expect 401)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] } }],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/talentos" }
        }
      ]
    }
  ]
}
